<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B12"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/configTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose widget folders"
        android:textColor="#F8FAFC"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/configSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Select a parent folder to include its subfolders."
        android:textColor="#CBD5E1"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/searchInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/app_panel_bg"
        android:hint="Search folders"
        android:imeOptions="actionDone"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="#F8FAFC"
        android:textColorHint="#64748B" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/selectCameraButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/app_button_tertiary_bg"
            android:text="Camera"
            android:textAllCaps="false"
            android:textColor="#E2E8F0" />

        <Button
            android:id="@+id/selectDownloadsButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginHorizontal="6dp"
            android:layout_weight="1"
            android:background="@drawable/app_button_tertiary_bg"
            android:text="Downloads"
            android:textAllCaps="false"
            android:textColor="#E2E8F0" />

        <Button
            android:id="@+id/clearAllButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/app_button_tertiary_bg"
            android:text="Clear"
            android:textAllCaps="false"
            android:textColor="#E2E8F0" />
    </LinearLayout>

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Loading folders…"
        android:textColor="#94A3B8"
        android:textSize="14sp" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:indeterminate="true" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/folderRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="10dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/app_button_primary_bg"
        android:enabled="false"
        android:text="Save widget folders"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" />
</LinearLayout>
